{
  "expo": {
    "name": "RavenSharp",
    "slug": "ravensharp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "ravensharp",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Scan your photos to find duplicates",
        "NSPhotoLibraryAddUsageDescription": "Save cleaned-up photos back to your library"
      },
      "bundleIdentifier": "com.emergent.fileunifier.l1ct33"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#000"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "READ_MEDIA_IMAGES",
        "READ_MEDIA_VIDEO",
        "READ_EXTERNAL_STORAGE"
      ],
      "package": "com.emergent.fileunifier.l1ct33"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#05050D"
        }
      ],
      "expo-font",
      [
        "expo-media-library",
        {
          "photosPermission": "Scan your photos to find duplicates",
          "savePhotosPermission": "Save cleaned-up photos back to your library",
          "isAccessMediaLocationEnabled": false
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
