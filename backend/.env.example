MONGO_URL=mongodb+srv://user:pass@cluster.mongodb.net
DB_NAME=ravensharp_smartcleaner
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Direct Anthropic API — replaces Emergent's EMERGENT_LLM_KEY/emergentintegrations,
# which only worked inside Emergent's own platform.
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-5

# Google Drive + Google Photos share Google OAuth, but need separate scopes:
#   Drive:  https://www.googleapis.com/auth/drive
#   Photos: https://www.googleapis.com/auth/photoslibrary.readonly
# Dropbox and OneDrive (Microsoft Graph) need their own app registrations.
# These are per-connection access tokens supplied by the frontend OAuth flow,
# not server-side secrets — nothing to set here for them specifically.
